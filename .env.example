# Copy to .env and fill in secrets:  cp .env.example .env
# Never commit .env.

SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
PORT=3000

SHOPIFY_LOCATION_ID=gid://shopify/Location/XXXXXXXXXXXXXXX

# Publications (merged): comma list and/or indexed vars SHOPIFY_PUBLICATION_ID_1, _2, ...
SHOPIFY_PUBLICATION_IDS=
SHOPIFY_PUBLICATION_ID_1=gid://shopify/Publication/XXXXXXXXXXXXXXX

# Optional — asset URLs for migration (defaults to https://www.usalight.com)
SOURCE_FILE_BASE_URL=https://www.usalight.com

# Optional — base URL for collection links in category migration (defaults to SHOPIFY_STORE)
# SHOPIFY_COLLECTION_URL_BASE=
